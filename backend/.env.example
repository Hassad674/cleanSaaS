# Server
PORT=8081
APP_ENV=development

# Database (local Docker — see docker-compose.yml)
DATABASE_URL=postgres://postgres:postgres@localhost:5433/cleansaas?sslmode=disable

# Auth — REQUIRED. Generate with: openssl rand -hex 32
JWT_SECRET=dev-secret-change-me-min-32-chars-long-required-in-prod

# URLs
FRONTEND_URL=http://localhost:3010
ADMIN_URL=http://localhost:5174

# Stripe (optional — leave empty to disable billing module)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Resend — Email (optional)
RESEND_API_KEY=

# AI providers (optional — enable the ones you want to use)
CLAUDE_API_KEY=
OPENAI_API_KEY=
GEMINI_API_KEY=

# Cloudflare R2 — Storage (optional)
R2_ACCOUNT_ID=
R2_ACCESS_KEY=
R2_SECRET_KEY=
R2_BUCKET_NAME=
R2_PUBLIC_URL=

# OAuth Google (optional)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URL=http://localhost:8081/api/auth/google/callback

# PostHog Analytics (optional)
POSTHOG_API_KEY=
POSTHOG_PROJECT_ID=
POSTHOG_HOST=https://eu.i.posthog.com
